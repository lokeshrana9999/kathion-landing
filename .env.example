# Copy to .env for local API / vercel dev (never commit secrets).
#
# Vercel: any file in /api is deployed as a serverless function (see
# https://vercel.com/docs/functions/functions-api-reference — “other” frameworks).
# This app exposes POST /api/waitlist after you connect the repo and set env vars.

# PostgreSQL — URL-encode special chars in the password ($ → %24, + → %2B, ! → %21).
# Use sslmode=verify-full (Node pg; see https://www.postgresql.org/docs/current/libpq-ssl.html).
#
# Vercel / serverless: use the TRANSACTION pooler (port 6543).
# Do NOT use direct db.<ref>.supabase.co:5432 on Vercel — often ENOTFOUND.
#
# Supabase → Project Settings → Database → Connection string → URI → Transaction pooler.
# Copy host, port (6543), and username exactly (often postgres.<PROJECT_REF>).
#
# Example shapes (replace PROJECT_REF, REGION pool, YOUR_PASSWORD with dashboard values):
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=verify-full
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=verify-full
#
# Optional — direct Postgres on your machine only (not recommended for Vercel):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=verify-full

DATABASE_URL=postgresql://postgres.<PROJECT_REF>:YOUR_PASSWORD@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=verify-full

# Supabase + pg: TLS still encrypts; by default we use ssl.rejectUnauthorized=false for
# *.supabase.{com,co} to avoid SELF_SIGNED_CERT_IN_CHAIN on Vercel. Set strict verify:
# DATABASE_SSL_STRICT=1

# Force TLS relax for any host (e.g. local corporate TLS inspection). Do not use with random DBs.
# DATABASE_SSL_REJECT_UNAUTHORIZED=0

# Optional: local Vite calls Vercel dev
# VITE_WAITLIST_URL=http://localhost:3000/api/waitlist
