# Copy to .env for local API / vercel dev (never commit secrets).
#
# Vercel: any file in /api is deployed as a serverless function (see
# https://vercel.com/docs/functions/functions-api-reference — “other” frameworks).
# This app exposes POST /api/waitlist after you connect the repo and set env vars.

# PostgreSQL — URL-encode special chars in the password ($ → %24, + → %2B, ! → %21).
# Use sslmode=verify-full (matches what pg v8 did for require; avoids Node pg deprecation
# warnings; see https://www.postgresql.org/docs/current/libpq-ssl.html).
#
# Vercel / serverless: prefer the TRANSACTION pooler (port 6543), NOT direct db.*:5432.
# Direct host often fails with: getaddrinfo ENOTFOUND db.<ref>.supabase.co
#
# Supabase → Project Settings → Database → Connection string → Method: URI
# → “Pooler” / “Transaction pooler” (host like aws-0-<REGION>.pooler.supabase.com:6543).
#
# Example shape (use values from your dashboard):
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=verify-full
#
# Local / long-lived connections can use direct (optional):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=verify-full

DATABASE_URL=postgresql://postgres.<PROJECT_REF>:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=verify-full

# Local Node only if connect fails with SELF_SIGNED_CERT_IN_CHAIN (e.g. corporate TLS inspection).
# Do not set on Vercel. Then run: npm run verify:waitlist
# DATABASE_SSL_REJECT_UNAUTHORIZED=0

# Optional: local Vite calls Vercel dev
# VITE_WAITLIST_URL=http://localhost:3000/api/waitlist
